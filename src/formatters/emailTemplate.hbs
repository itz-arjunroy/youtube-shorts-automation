<!DOCTYPE html>
<html>
<head>
    <style>
        body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }
        .container { max-width: 600px; margin: 0 auto; padding: 20px; border: 1px solid #ddd; border-radius: 8px; }
        .header { text-align: center; border-bottom: 2px solid #ff0000; padding-bottom: 10px; }
        .video-card { margin: 20px 0; padding: 15px; border: 1px solid #eee; border-radius: 8px; background: #fafafa; }
        .video-thumb { width: 100%; border-radius: 8px; }
        .video-title { font-size: 18px; margin: 10px 0; color: #000; text-decoration: none; display: block; }
        .stats { font-size: 14px; color: #666; }
        .summary { background: #fefefe; padding: 10px; border-radius: 5px; margin-bottom: 20px; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>Daily Shorts Viral Report</h1>
            <p>{{date}}</p>
        </div>
        
        <div class="summary">
            <h3>📊 Summary</h3>
            <ul>
                <li>Videos Found: {{stats.totalFound}}</li>
                <li>Videos Passing Filters: {{stats.totalFiltered}}</li>
                <li>Duplicates Removed: {{stats.duplicatesRemoved}}</li>
            </ul>
        </div>

        {{#each videos}}
        <div class="video-card">
            <img src="{{this.thumbnailUrl}}" class="video-thumb" alt="{{this.title}}">
            <a href="{{this.videoUrl}}" class="video-title">{{this.title}}</a>
            <p class="stats">
                <b>Channel:</b> {{this.channelTitle}}<br>
                <b>Views:</b> {{this.viewCount}}<br>
                <b>Likes:</b> {{this.likeCount}}<br>
                <b>Like Ratio:</b> {{this.likeRatio}}%
            </p>
        </div>
        {{/each}}
        
        <div class="footer" style="text-align: center; font-size: 12px; color: #999; margin-top: 30px;">
            <p>Generated by YouTube Shorts Automation</p>
        </div>
    </div>
</body>
</html>
