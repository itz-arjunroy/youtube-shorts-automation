<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            font-family: 'Segoe UI', -apple-system, BlinkMacSystemFont, Roboto, Oxygen, Ubuntu, sans-serif;
            background: #f0f2f5;
            color: #1a1a2e;
            line-height: 1.6;
        }
        
        .email-wrapper {
            max-width: 600px;
            margin: 0 auto;
            background: #ffffff;
        }
        
        .header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            padding: 40px 30px;
            text-align: center;
            color: white;
        }
        
        .header h1 {
            font-size: 24px;
            font-weight: 700;
            margin-bottom: 8px;
            letter-spacing: -0.5px;
        }
        
        .header .date {
            font-size: 14px;
            opacity: 0.9;
        }
        
        .badge-row {
            display: flex;
            justify-content: center;
            gap: 15px;
            margin-top: 20px;
            flex-wrap: wrap;
        }
        
        .badge {
            background: rgba(255,255,255,0.2);
            padding: 8px 16px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 600;
        }
        
        .content {
            padding: 30px;
        }
        
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 15px;
            margin-bottom: 30px;
        }
        
        .stat-card {
            background: #f8f9fa;
            border-radius: 12px;
            padding: 20px 15px;
            text-align: center;
        }
        
        .stat-card .number {
            font-size: 28px;
            font-weight: 700;
            color: #667eea;
        }
        
        .stat-card .label {
            font-size: 12px;
            color: #6c757d;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-top: 4px;
        }
        
        .section-title {
            font-size: 18px;
            font-weight: 600;
            color: #1a1a2e;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .video-card {
            background: #ffffff;
            border: 1px solid #e9ecef;
            border-radius: 16px;
            overflow: hidden;
            margin-bottom: 20px;
            transition: box-shadow 0.2s ease;
        }
        
        .video-card:hover {
            box-shadow: 0 8px 25px rgba(0,0,0,0.08);
        }
        
        .video-header {
            display: flex;
            align-items: center;
            padding: 16px;
            gap: 12px;
        }
        
        .thumbnail {
            width: 100px;
            height: 56px;
            border-radius: 8px;
            object-fit: cover;
            flex-shrink: 0;
        }
        
        .video-info {
            flex: 1;
            min-width: 0;
        }
        
        .video-title {
            font-size: 15px;
            font-weight: 600;
            color: #1a1a2e;
            margin-bottom: 4px;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        
        .channel-name {
            font-size: 13px;
            color: #6c757d;
        }
        
        .video-stats {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            border-top: 1px solid #e9ecef;
        }
        
        .stat-item {
            padding: 12px 8px;
            text-align: center;
            border-right: 1px solid #e9ecef;
        }
        
        .stat-item:last-child {
            border-right: none;
        }
        
        .stat-item .value {
            font-size: 16px;
            font-weight: 700;
            color: #1a1a2e;
        }
        
        .stat-item .label {
            font-size: 10px;
            color: #6c757d;
            text-transform: uppercase;
            letter-spacing: 0.3px;
        }
        
        .stat-item.highlight .value {
            color: #667eea;
        }
        
        .watch-btn {
            display: block;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            text-align: center;
            padding: 14px;
            text-decoration: none;
            font-weight: 600;
            font-size: 14px;
            border-radius: 10px;
            margin: 0 16px 16px;
        }
        
        .watch-btn:hover {
            opacity: 0.9;
        }
        
        .criteria-box {
            background: #f8f9fa;
            border-radius: 12px;
            padding: 20px;
            margin-top: 30px;
        }
        
        .criteria-box h4 {
            font-size: 14px;
            color: #6c757d;
            margin-bottom: 12px;
        }
        
        .criteria-list {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 8px;
        }
        
        .criteria-item {
            font-size: 13px;
            color: #495057;
        }
        
        .criteria-item span {
            font-weight: 600;
            color: #1a1a2e;
        }
        
        .no-videos {
            text-align: center;
            padding: 50px 20px;
        }
        
        .no-videos .icon {
            font-size: 48px;
            margin-bottom: 16px;
        }
        
        .no-videos h3 {
            font-size: 18px;
            color: #1a1a2e;
            margin-bottom: 8px;
        }
        
        .no-videos p {
            color: #6c757d;
            font-size: 14px;
        }
        
        .footer {
            background: #f8f9fa;
            padding: 25px;
            text-align: center;
            border-top: 1px solid #e9ecef;
        }
        
        .footer p {
            font-size: 12px;
            color: #6c757d;
        }
        
        @media (max-width: 480px) {
            .stats-grid {
                grid-template-columns: repeat(3, 1fr);
                gap: 10px;
            }
            .stat-card {
                padding: 15px 10px;
            }
            .stat-card .number {
                font-size: 22px;
            }
            .video-stats {
                grid-template-columns: repeat(2, 1fr);
            }
            .criteria-list {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="email-wrapper">
        <div class="header">
            <h1>🎬 YouTube Shorts Report</h1>
            <div class="date">{{date}}</div>
            <div class="badge-row">
                <span class="badge">🔥 Fresh Content</span>
                <span class="badge">{{stats.totalFiltered}} Trending</span>
            </div>
        </div>
        
        <div class="content">
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="number">{{stats.totalFound}}</div>
                    <div class="label">Searched</div>
                </div>
                <div class="stat-card">
                    <div class="number">{{stats.totalFiltered}}</div>
                    <div class="label">Viral Hits</div>
                </div>
                <div class="stat-card">
                    <div class="number">{{stats.duplicatesRemoved}}</div>
                    <div class="label">Skipped</div>
                </div>
            </div>
            
            {{#if videos.length}}
            <div class="section-title">🎯 Trending Videos</div>
            
            {{#each videos}}
            <div class="video-card">
                <div class="video-header">
                    <img src="{{this.thumbnailUrl}}" class="thumbnail" alt="thumbnail">
                    <div class="video-info">
                        <div class="video-title">{{this.title}}</div>
                        <div class="channel-name">{{this.channelTitle}}</div>
                    </div>
                </div>
                <div class="video-stats">
                    <div class="stat-item highlight">
                        <div class="value">{{this.viewCount}}</div>
                        <div class="label">Views</div>
                    </div>
                    <div class="stat-item">
                        <div class="value">{{this.likeCount}}</div>
                        <div class="label">Likes</div>
                    </div>
                    <div class="stat-item">
                        <div class="value">{{this.engagementRate}}%</div>
                        <div class="label">Engagement</div>
                    </div>
                    <div class="stat-item">
                        <div class="value">{{this.ageHours}}h</div>
                        <div class="label">Age</div>
                    </div>
                </div>
                <a href="{{this.videoUrl}}" class="watch-btn">▶ Watch Now</a>
            </div>
            {{/each}}
            
            {{else}}
            <div class="no-videos">
                <div class="icon">📭</div>
                <h3>No Viral Videos Today</h3>
                <p>No videos met your criteria in the last 24 hours. Check back tomorrow!</p>
            </div>
            {{/if}}
            
            <div class="criteria-box">
                <h4>Filter Criteria Applied</h4>
                <div class="criteria-list">
                    <div class="criteria-item"><span>20K+</span> Minimum Views</div>
                    <div class="criteria-item"><span>2%+</span> Like Ratio</div>
                    <div class="criteria-item"><span>3%+</span> Engagement Rate</div>
                    <div class="criteria-item"><span>24h</span> Max Age</div>
                </div>
            </div>
        </div>
        
        <div class="footer">
            <p>Generated by YouTube Shorts Automation • Powered by YouTube Data API</p>
        </div>
    </div>
</body>
</html>
